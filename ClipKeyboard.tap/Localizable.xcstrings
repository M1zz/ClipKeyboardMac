{
  "sourceLanguage": "en",
  "strings": {
    "": {},
    "'%@'와 일치하는 항목이 없습니다": {
      "comment": "No results for search query",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No items match '%@'"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "'%@'와 일치하는 항목이 없습니다"
          }
        }
      }
    },
    "[%@] 클립보드에 복사되었습니다": {
      "comment": "Clipboard copy toast",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "[%@] copied to clipboard"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "[%@] 클립보드에 복사되었습니다"
          }
        }
      }
    },
    "{ }로 감싸면 입력할 때 채우는 칸이 됩니다": {
      "comment": "Custom placeholder hint",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wrap text in { } to make a fill-in field"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "{ }로 감싸면 입력할 때 채우는 칸이 됩니다"
          }
        }
      }
    },
    "%d개": {
      "comment": "Item count",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%d"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%d개"
          }
        }
      }
    },
    "%d개 단축어 잠김 — iOS에서 Pro 구매 시 동기화됩니다": {
      "comment": "Locked memos banner",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%d snippets locked — synced when you buy Pro on iOS"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%d개 단축어 잠김 — iOS에서 Pro 구매 시 동기화됩니다"
          }
        }
      }
    },
    "%d개의 항목": {
      "comment": "Item count",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%d items"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%d개의 항목"
          }
        }
      }
    },
    "%lld": {
      "comment": "A label showing the index of a memo in the list of ordered memos. The argument is the 1-based index of the memo.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld"
          }
        }
      }
    },
    "+%lld": {
      "comment": "A label that shows the number of additional images in a memo. The argument is the number of additional images in the memo.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "+%lld"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "+%lld"
          }
        }
      }
    },
    "⌃⌥K로 어디서나 빠르게 접근": {
      "comment": "Global shortcuts description",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick access anywhere with ⌃⌥K"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "⌃⌥K로 어디서나 빠르게 접근"
          }
        }
      }
    },
    "⌘%lld": {
      "comment": "A badge displaying the keyboard shortcut to access a memo. The argument is the keyboard shortcut.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "⌘%lld"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "⌘%lld"
          }
        }
      }
    },
    "⚠️ 복구 시 현재 데이터가 백업 데이터로 교체됩니다": {
      "comment": "Restore warning",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Restoring replaces your current data with the backup"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ 복구 시 현재 데이터가 백업 데이터로 교체됩니다"
          }
        }
      }
    },
    "📁 파일 백업은 iCloud와 별개로 데이터를 파일로 보관하는 가장 확실한 방법입니다. 가져오기는 현재 데이터를 지우지 않고 합칩니다.": {
      "comment": "File backup info",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "📁 File backup is the most reliable way to keep your data as a file, separate from iCloud. Importing merges into your current data without erasing it."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "📁 파일 백업은 iCloud와 별개로 데이터를 파일로 보관하는 가장 확실한 방법입니다. 가져오기는 현재 데이터를 지우지 않고 합칩니다."
          }
        }
      }
    },
