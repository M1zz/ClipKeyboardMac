# 앱별 fastlane 설정 — 이 파일이 이 앱(맥OS 탭클립키보드)의 배포 설정 전부다.
FASTLANE_SHARED_DIR=/Users/hyunholee/Documents/workspace/fastlane-shared
SCHEME=ClipKeyboard.tap

# 빌드 번호는 Version.xcconfig 의 CURRENT_PROJECT_VERSION 으로 중앙 관리
VERSION_XCCONFIG=Version.xcconfig

# 배포 전 게이트: 공유 파일(Shared/)이 iOS 앱 원본과 일치하는지 검사 (드리프트 방지)
PREDEPLOY_SCRIPT=scripts/check_shared_drift.sh

# 선택: fastlane/metadata 폴더를 관리하면 false 로 (deliver download_metadata 로 받아오기)
#SKIP_METADATA=true

# 선택: 심사 제출 없이 업로드만 하려면 false
#SUBMIT_FOR_REVIEW=true
